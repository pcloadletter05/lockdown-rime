{
  "meta": {
    "version": 1,
    "description": "Call disposition log records for CATI operations",
    "schema": {
      "date": "string - call date",
      "time": "string - call time",
      "phone": "string - dialed number (redacted)",
      "disposition": "string - disposition code (see disposition_codes)",
      "duration": "string|null - call duration",
      "interviewer": "string - interviewer ID or name",
      "notes": "string|null - call notes"
    },
    "disposition_codes": {
      "Complete": "Full survey administered and recorded.",
      "Complete (text)": "Full survey administered over SMS rather than voice. Channel substitution; survey responses are entered into the standard CATI record the same way as a voice complete. No separate transcript artifact is retained. Off-script: not currently covered by the CATI flipbook (l.milavic ad hoc, pending Margaret review).",
      "Partial": "Survey started but not completed; respondent broke off mid-script.",
      "Callback": "Respondent answered but asked to be called at a later time.",
      "Refusal": "Respondent declined to participate after consent script.",
      "Hangup": "Respondent picked up but disconnected before consent script completed; not coded as Refusal because the respondent did not decline the survey itself, only the channel/timing.",
      "No Answer": "Line rang out; no pickup, no voicemail.",
      "Voicemail": "Voicemail reached; message left.",
      "Busy": "Line busy; no contact made.",
      "Disconnected": "Number reported as disconnected by carrier."
    }
  },
  "columns": [
    "Date",
    "Time",
    "Phone",
    "Disposition",
    "Duration",
    "Interviewer",
    "Notes"
  ],
